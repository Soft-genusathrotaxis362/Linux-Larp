#!/bin/sh

sleep 4

WALLPAPER="/usr/share/backgrounds/linux-larp/lain.png"

# Update any XFCE wallpaper properties that already exist.
for prop in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep '/last-image$'); do
    xfconf-query -c xfce4-desktop -p "$prop" -s "$WALLPAPER" || true
done

for prop in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep '/image-style$'); do
    xfconf-query -c xfce4-desktop -p "$prop" -s 5 || true
done

# Also create settings for currently connected displays.
for output in $(xrandr 2>/dev/null | awk '/ connected/{print $1}'); do
    BASE="/backdrop/screen0/monitor${output}/workspace0"

    xfconf-query -c xfce4-desktop -p "$BASE/last-image" --create -t string -s "$WALLPAPER" || true
    xfconf-query -c xfce4-desktop -p "$BASE/image-style" --create -t int -s 5 || true
done

# Common QEMU/XFCE fallback names.
for monitor in monitorVirtual1 monitorVirtual-1 monitorVGA-1 monitorDefault; do
    BASE="/backdrop/screen0/${monitor}/workspace0"

    xfconf-query -c xfce4-desktop -p "$BASE/last-image" --create -t string -s "$WALLPAPER" || true
    xfconf-query -c xfce4-desktop -p "$BASE/image-style" --create -t int -s 5 || true
done
