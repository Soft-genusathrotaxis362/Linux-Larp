#!/bin/sh
set -e

update-alternatives --install /usr/bin/x-terminal-emulator x-terminal-emulator /usr/local/bin/hackermode-terminal 200 || true
update-alternatives --set x-terminal-emulator /usr/local/bin/hackermode-terminal || true

for desktop in /usr/share/applications/*terminal*.desktop; do
    [ -f "$desktop" ] || continue

    case "$desktop" in
        *real-terminal.desktop|*hackermode.desktop)
            continue
            ;;
    esac

    sed -i 's|^Exec=.*|Exec=/usr/local/bin/hackermode-terminal|' "$desktop" || true
    sed -i 's|^Name=.*|Name=hackermode|' "$desktop" || true
    sed -i 's|^Comment=.*|Comment=Hacking terminal made FOR HACKERS by HACKERS|' "$desktop" || true
done

if [ -x /usr/bin/xfce4-terminal ] && [ ! -e /usr/bin/xfce4-terminal.real ]; then
    mv /usr/bin/xfce4-terminal /usr/bin/xfce4-terminal.real
    ln -s /usr/local/bin/hackermode-terminal /usr/bin/xfce4-terminal
fi

# motd tsuttf
if ! grep -q "LINUX_LARP_MOTD" /etc/bash.bashrc; then
    cat >> /etc/bash.bashrc <<'EOF'


if [ -t 1 ] && [ -f /etc/motd ]; then
    cat /etc/motd
    echo
fi
EOF
fi

exit 0
