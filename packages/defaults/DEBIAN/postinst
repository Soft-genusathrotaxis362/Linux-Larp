#!/bin/sh
set -e

cat > /etc/os-release <<'EOF'
PRETTY_NAME="Linux Larp 1.0"
NAME="Linux Larp"
VERSION_ID="1.0"
VERSION="1.0"
ID=linux-larp
ID_LIKE=debian
HOME_URL="https://localhost"
SUPPORT_URL="https://localhost"
BUG_REPORT_URL="https://localhost"
EOF

cat > /usr/lib/os-release <<'EOF'
PRETTY_NAME="Linux Larp 1.0"
NAME="Linux Larp"
VERSION_ID="1.0"
VERSION="1.0"
ID=linux-larp
ID_LIKE=debian
HOME_URL="https://localhost"
SUPPORT_URL="https://localhost"
BUG_REPORT_URL="https://localhost"
EOF


update-alternatives --install /usr/bin/x-www-browser x-www-browser /usr/bin/google-chrome-stable 200 || true
update-alternatives --set x-www-browser /usr/bin/google-chrome-stable || true

update-alternatives --install /usr/bin/gnome-www-browser gnome-www-browser /usr/bin/google-chrome-stable 200 || true
update-alternatives --set gnome-www-browser /usr/bin/google-chrome-stable || true

apt-get purge -y firefox-esr chromium chromium-common chromium-sandbox epiphany-browser || true
apt-get autoremove -y || true

for app in \
    firefox-esr.desktop \
    org.mozilla.firefox.desktop \
    chromium.desktop \
    chromium-browser.desktop \
    org.gnome.Epiphany.desktop \
    epiphany.desktop
do
    if [ -f "/usr/share/applications/$app" ]; then
        echo "NoDisplay=true" >> "/usr/share/applications/$app"
    fi
done

exit 0
